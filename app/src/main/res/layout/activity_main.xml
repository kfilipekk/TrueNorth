<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#070D1A">

    <org.osmdroid.views.MapView
        android:id="@+id/map"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <com.truenorth.app.NavigationMapView
        android:id="@+id/navigationMap"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@android:color/transparent" />

    <!-- Professional HUD Panel -->
    <LinearLayout
        android:id="@+id/hudPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#CC070D1A"
        android:orientation="vertical"
        android:padding="8dp"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/txtCoords"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="LAT: 0.000000 LON: 0.000000"
                    android:textColor="#00FF88"
                    android:textSize="10sp"
                    android:fontFamily="monospace" />
                <TextView
                    android:id="@+id/txtAlt"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ALT: 0.0m (Δ 0.0m)"
                    android:textColor="#00FF88"
                    android:textSize="10sp"
                    android:fontFamily="monospace" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="end">
                <TextView
                    android:id="@+id/txtMode"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MODE: GPS_LOCK"
                    android:textColor="#00FF88"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace" />
                <TextView
                    android:id="@+id/txtUncertainty"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="UNCERTAINTY: 0.0m"
                    android:textColor="#00FF88"
                    android:textSize="10sp"
                    android:fontFamily="monospace" />
            </LinearLayout>
        </LinearLayout>

        <!-- Sensor Status HUD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:orientation="horizontal"
            android:gravity="center">
            <TextView
                android:id="@+id/statusImu"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="IMU [OK]"
                android:textColor="#00FF88"
                android:textSize="9sp"
                android:fontFamily="monospace"
                android:paddingEnd="12dp" />
            <TextView
                android:id="@+id/statusBaro"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BARO [OK]"
                android:textColor="#00FF88"
                android:textSize="9sp"
                android:fontFamily="monospace"
                android:paddingEnd="12dp" />
            <TextView
                android:id="@+id/statusCell"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CELL [OK]"
                android:textColor="#00FF88"
                android:textSize="9sp"
                android:fontFamily="monospace" />
        </LinearLayout>
    </LinearLayout>

    <!-- Kalman Info Panel -->
    <LinearLayout
        android:id="@+id/kalmanPanel"
        android:layout_width="220dp"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:background="#BB000000"
        android:orientation="vertical"
        android:padding="10dp"
        app:layout_constraintTop_toBottomOf="@id/hudPanel"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="EKF INTERNALS (STATE VECTOR)"
            android:textColor="#FFFFFF"
            android:textSize="9sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtEkfState"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="x = [N, E, A, H, V]"
            android:textColor="#00D4FF"
            android:textSize="8sp"
            android:fontFamily="monospace"
            android:lineSpacingExtra="2dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="P COVARIANCE (UNCERTAINTY)"
            android:textColor="#FFFFFF"
            android:textSize="9sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtEkfCov"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="diag(P) = [...]"
            android:textColor="#FFB300"
            android:textSize="8sp"
            android:fontFamily="monospace"
            android:lineSpacingExtra="2dp" />
    </LinearLayout>

    <!-- Professional Simulation Overlay -->
    <LinearLayout
        android:id="@+id/simPanel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:background="#99000000"
        android:orientation="vertical"
        android:padding="8dp"
        app:layout_constraintBottom_toTopOf="@id/logView"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SIMULATION CONTROL"
            android:textColor="#FFFFFF"
            android:textSize="10sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnJamming"
            android:layout_width="140dp"
            android:layout_height="56dp"
            android:layout_marginTop="8dp"
            android:backgroundTint="#AA112233"
            android:text="JAM GPS"
            android:textColor="#00FF88"
            android:textSize="14sp"
            android:textStyle="bold"
            app:icon="@drawable/ic_jamming_off"
            app:iconTint="#00FF88"
            app:cornerRadius="8dp"
            app:strokeColor="#44FFFFFF"
            app:strokeWidth="1dp" />

        <Button
            android:id="@+id/btnForceStart"
            android:layout_width="140dp"
            android:layout_height="40dp"
            android:layout_marginTop="4dp"
            android:backgroundTint="#44FFFFFF"
            android:text="FORCE START"
            android:textColor="#CCDDEE"
            android:textSize="10sp"
            app:cornerRadius="8dp"
            android:visibility="gone" />

    </LinearLayout>

    <TextView
        android:id="@+id/logView"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:background="#99000000"
        android:padding="8dp"
        android:textColor="#00FF88"
        android:textSize="12sp"
        android:fontFamily="monospace"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
